<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>KVI Predictive Margin Defense Simulator</title>
    <style>
        :root {
            --dark-blue: #1a2433;
            --alert-red: #b32525;
            --success-green: #27ae60;
            --text-color: #ffffff;
        }
        body { font-family: 'Segoe UI', Helvetica, Arial, sans-serif; background-color: var(--dark-blue); color: var(--text-color); margin: 0; padding: 20px; }
        header { border-bottom: 2px solid var(--alert-red); padding-bottom: 10px; margin-bottom: 20px; }
        .kicker { color: var(--alert-red); font-weight: bold; text-transform: uppercase; letter-spacing: 1px; font-size: 0.8rem; }
        h1 { font-family: 'Georgia', serif; margin: 5px 0; }
        .meta-table { width: 100%; border-collapse: collapse; margin-bottom: 20px; font-size: 0.9rem; }
        .meta-table td { padding: 8px; border: 1px solid #334; }
        .dashboard-container { display: grid; grid-template-columns: 300px 1fr; gap: 20px; }
        .control-panel { background: #232d3d; padding: 20px; border-radius: 4px; }
        .main-panel { background: #232d3d; padding: 20px; border-radius: 4px; }
        .control-group { margin-bottom: 20px; }
        label { display: block; margin-bottom: 5px; font-size: 0.9rem; }
        input[type="range"] { width: 100%; }
        .result-box { font-size: 1.5rem; font-weight: bold; color: var(--success-green); }
        .disclaimer { font-size: 0.7rem; color: #888; margin-top: 20px; font-style: italic; }
    </style>
</head>
<body>

<header>
    <div class="kicker">Strategic Analytics Engine</div>
    <h1>Enterprise KVI Indexing Simulator</h1>
</header>

<table class="meta-table">
    <tr><td><strong>Analyst:</strong> Austin Sonny Stethem</td><td><strong>Module:</strong> Predictive Margin Defense</td></tr>
    <tr><td><strong>Tech Stack:</strong> SQL, Phocas BI, ERP-Waterfall Logic</td><td><strong>Status:</strong> Active Logic Simulation</td></tr>
</table>

<div class="dashboard-container">
    <aside class="control-panel">
        <h3>Model Inputs</h3>
        <div class="control-group">
            <label>Logistics Cost Multiplier (<span id="log-val">1.0</span>x)</label>
            <input type="range" id="log-slider" min="1" max="2" step="0.05" value="1.0" oninput="updateModel()">
        </div>
        <div class="control-group">
            <label>Market Competitor Pressure (0 - 100)</label>
            <input type="range" id="comp-slider" min="0" max="100" value="20" oninput="updateModel()">
        </div>
        <div class="control-group">
            <label>Sentiment Trust Weight (0 - 1.0)</label>
            <input type="range" id="sent-slider" min="0" max="1" step="0.1" value="0.5" oninput="updateModel()">
        </div>
    </aside>

    <main class="main-panel">
        <h3>Projected Margin Health</h3>
        <div id="result" class="result-box">Margin: 24.5%</div>
        <p>This visualization calculates the automated price waterfall based on your current inputs. By adjusting the logistics multiplier and competitive pressure, the engine simulates an auto-indexing event for a KVI brake component family.</p>
        <div class="disclaimer">
            * Disclaimer: This tool uses randomized/proxy data to comply with NDAs while demonstrating exact production pricing logic.
        </div>
    </main>
</div>

<script>
    function updateModel() {
        const log = parseFloat(document.getElementById('log-slider').value);
        const comp = parseFloat(document.getElementById('comp-slider').value);
        const sentiment = parseFloat(document.getElementById('sent-slider').value);
        
        document.getElementById('log-val').innerText = log.toFixed(2);
        
        // Logic: Base Margin (30%) - (Logistics Impact) - (Competitor Friction adjusted by Sentiment Trust)
        let baseMargin = 30.0;
        let logImpact = (log - 1) * 5; // Higher logistics costs eat 5% margin per 0.1 increase
        let compImpact = (comp / 100) * 8 * sentiment; // Competitor pressure impact scaled by trust
        
        let finalMargin = baseMargin - logImpact - compImpact;
        
        const resEl = document.getElementById('result');
        resEl.innerText = "Projected Margin: " + finalMargin.toFixed(1) + "%";
        resEl.style.color = finalMargin < 20 ? "#b32525" : "#27ae60";
    }
    updateModel();
</script>

</body>
</html>
